{
  "$schema": "https://typedoc.org/schema.json",
  "entryPointStrategy": "packages",
  "entryPoints": [
    "packages/engine",
    "packages/logger",
    "packages/tournament",
    "apps/server",
    "apps/web"
  ],
  "out": "docs/api",
  "plugin": ["typedoc-plugin-markdown"],
  "readme": "none",
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "githubPages": false,
  "hideGenerator": true,
  "skipErrorChecking": true,
  "gitRevision": "main"
}
