{
  "name": "nlc-darts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "repository": "https://github.com/keenanlk/granboard-client.git",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:electron": "electron-builder",
    "build:web": "BUILD_TARGET=web tsc -b && vite build",
    "cap:sync": "npm run build:web && cap sync",
    "cap:ios": "npm run cap:sync && cap open ios",
    "lint": "eslint . && tsc",
    "test": "vitest run",
    "preview": "vite preview",
    "postinstall": "electron-rebuild"
  },
  "dependencies": {
    "@abandonware/noble": "^1.9.2-26",
    "@capacitor-community/bluetooth-le": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "idb": "^8.0.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-mcp": "^0.3.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0",
    "zustand": "^5.0.11"
  },
  "build": {
    "appId": "com.nlc.darts",
    "productName": "NLC Darts",
    "publish": null,
    "icon": "public/AppIcons/Assets.xcassets/AppIcon.appiconset/1024.png",
    "mac": {
      "category": "public.app-category.sports-games",
      "extendInfo": {
        "NSBluetoothAlwaysUsageDescription": "NLC Darts needs Bluetooth to connect to the GranBoard dartboard."
      }
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/@abandonware/**",
      "**/node_modules/bluetooth-hci-socket/**"
    ],
    "directories": {
      "buildResources": "public",
      "output": "release"
    }
  }
}
