# For local development with `supabase start`, use .env.development (auto-loaded).
# For production/staging, create .env.local with your real credentials (gitignored).
VITE_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
VITE_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
VITE_COLYSEUS_URL=ws://localhost:2567
VITE_LOG_LEVEL=info
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
