# For local development with `supabase start`, use .env.development (auto-loaded).
# For production/staging, create .env.local with your real credentials (gitignored).

# ── Required ─────────────────────────────────────────────────────────────────
# PORT is set automatically by Railway. For local dev, defaults to 2567.
# PORT=2567

# ── Supabase (required for lobby + result recording) ─────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Admin Panel ──────────────────────────────────────────────────────────────
# Set ADMIN_PASSWORD to enable the /admin/monitor dashboard.
# ADMIN_USER defaults to "admin" if not set.
# ADMIN_PASSWORD=changeme
# ADMIN_USER=admin

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Defaults to http://localhost:5173,capacitor://localhost in development.
# CORS_ORIGINS=https://your-app.com,capacitor://localhost

# ── Logging ──────────────────────────────────────────────────────────────────
# Pino log level: fatal, error, warn, info, debug, trace
# LOG_LEVEL=info

# ── Limits ───────────────────────────────────────────────────────────────────
# Maximum concurrent game rooms (default: 50)
# MAX_ROOMS=50
