{
  "name": "@nlc-darts/web",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "repository": "https://github.com/keenanlk/granboard-client.git",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "cap:sync": "npm run build && cap sync",
    "cap:ios": "npm run cap:sync && cap open ios",
    "dev:ios": "NODE_ENV=development npm run build && NODE_ENV=development cap run ios --livereload --external --target 00008150-00065C8222B8401C",
    "build:ios": "node scripts/buildIos.mjs",
    "lint": "eslint . && tsc -b && prettier --check .",
    "test": "COVERAGE_ONLY=1 vitest run --coverage",
    "preview": "vite preview",
    "sim": "tsx scripts/botSim.ts",
    "bump": "node scripts/version.mjs"
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "6.0.0",
    "@capacitor-community/bluetooth-le": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/screen-orientation": "^6.0.4",
    "@codetrix-studio/capacitor-google-auth": "3.4.0-rc.4",
    "@nlc-darts/engine": "workspace:*",
    "@nlc-darts/logger": "workspace:*",
    "@nlc-darts/supabase": "workspace:*",
    "@nlc-darts/tournament": "workspace:*",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@supabase/supabase-js": "^2.99.2",
    "colyseus.js": "^0.16.0",
    "idb": "^8.0.3",
    "konva": "^10.2.3",
    "lucide-react": "^0.577.0",
    "react-konva": "^19.2.3",
    "react-zoom-pan-pinch": "^3.7.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@nlc-darts/eslint-config": "workspace:*",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@types/web-bluetooth": "^0.0.21",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "eslint": "^9.39.1",
    "playwright": "^1.58.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "supabase": "^2.81.3",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-mcp": "^0.3.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0",
    "vitest-browser-react": "^2.1.0",
    "zustand": "^5.0.11"
  }
