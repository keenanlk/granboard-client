{
  "name": "nlc-darts",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "repository": "https://github.com/keenanlk/granboard-client.git",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "cap:sync": "npm run build && cap sync",
    "cap:ios": "npm run cap:sync && cap open ios",
    "dev:ios": "cap run ios --livereload --external",
    "build:ios": "node scripts/buildIos.mjs",
    "lint": "eslint . && tsc && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "preview": "vite preview",
    "sim": "tsx scripts/botSim.ts"
  },
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "idb": "^8.0.3",
    "lucide-react": "^0.577.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/web-bluetooth": "^0.0.21",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-mcp": "^0.3.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0",
    "zustand": "^5.0.11"
  }
}
